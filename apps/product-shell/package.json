{
  "name": "gateway-demo-zero",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:engage && npm run build:payme && npm run build:shell",
    "build:shell": "vite build",
    "preview": "vite preview",
    "build:engage": "npm --prefix ../modules/engage install --progress=false && npm --prefix ../modules/engage run build",
    "build:payme": "npm --prefix ../modules/payme install --progress=false && npm --prefix ../modules/payme run build",
    "test": "node --test tests/microfrontend/*.test.mjs",
    "test:pass5": "npm run test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.2"
  }
}
